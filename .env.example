# Copy to .env.local and adjust. The defaults below match `docker compose up -d`
# (Postgres + MinIO) and work out of the box for local development.

# Postgres. Password matches docker-compose's default; for a non-default DB
# password set POSTGRES_PASSWORD in a sibling .env (read by docker compose).
DATABASE_URL=postgres://webtunes:webtunes@localhost:5432/webtunes

# Auth.js. Generate a secret with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# S3-compatible storage. Defaults target the dev MinIO container.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=webtunes
S3_FORCE_PATH_STYLE=true

# Email. Without RESEND_API_KEY, lib/email.ts logs reset/verification links to
# the server console instead of sending (dev behavior).
RESEND_API_KEY=
EMAIL_FROM=webtunes@localhost

# Online metadata lookup (cover art / untagged-track identification). Without
# ACOUSTID_API_KEY (free, https://acoustid.org/api-key), acoustic fingerprint
# identification is skipped — iTunes cover-art lookup still works without a key.
# Requires the `fpcalc` binary on PATH (Debian: libchromaprint-tools).
# METADATA_CONTACT_EMAIL identifies WebTunes in the MusicBrainz/CAA User-Agent.
ACOUSTID_API_KEY=
METADATA_CONTACT_EMAIL=
