# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# CLAP model weights cache (downloaded on first embed; see lib/clap-embedding.ts)
/.transformers-cache

# Revert map written by scripts/remux-ogg-to-mp4.mjs (runtime artifact)
/remux-revert.jsonl

# Review/revert logs written by scripts/backfill-online-metadata.mjs
/backfill-online-review.jsonl
/backfill-online-revert.jsonl
